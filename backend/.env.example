# Конфигурация Транскрибатора
# Ключи вводятся через интерфейс приложения (Профиль / Настройки)

NODE_ENV=production
PORT=3000

# Groq API — бесплатный AI-анализ (получить на console.groq.com)
GROQ_API_KEY=

# HuggingFace — для диаризации спикеров (получить на huggingface.co/settings/tokens)
HF_TOKEN=

# Telegram бот (получить токен у @BotFather)
TELEGRAM_BOT_TOKEN=

# Ollama (если установлен локально)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen:2.5b
