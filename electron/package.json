{
  "name": "transcriptor",
  "version": "1.0.0",
  "description": "Локальный транскрибатор на Faster-Whisper",
  "author": "Supremeister",
  "repository": {
    "type": "git",
    "url": "https://github.com/Supremeister/Transcription-AI.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.transcriptor.app",
    "productName": "Транскрибатор",
    "directories": {
      "output": "../dist-exe"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../backend/src/",
        "to": "backend/",
        "filter": ["**/*", "!**/*.test.js"]
      },
      {
        "from": "../backend/node_modules/",
        "to": "backend/node_modules/"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/diarize.py",
        "to": "backend/diarize.py"
      },
      {
        "from": "../backend/.env.example",
        "to": "backend/.env"
      },
      {
        "from": "../frontend/dist/",
        "to": "frontend/"
      },
      {
        "from": "resources/node.exe",
        "to": "node.exe"
      },
      {
        "from": "../dist/whisper_service/",
        "to": "whisper_service/"
      },
      {
        "from": "../telegram_bot.py",
        "to": "telegram_bot.py"
      },
      {
        "from": "../setup.bat",
        "to": "setup.bat"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Транскрибатор",
      "artifactName": "Транскрибатор-Setup-${version}.exe",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "Supremeister",
      "repo": "Transcription-AI"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "form-data": "^4.0.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  }
}
